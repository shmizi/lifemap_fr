# LifeMap environment configuration — copy this file to `.env` and fill in values.
# `.env` is gitignored and is NEVER committed or bundled into the browser.
# DO NOT put real keys in THIS file — it is the committed template.

# Your Anthropic API key. SERVER-SIDE ONLY: it is read by the local dev proxy in
# vite.config.ts (the Node process), never by browser code. It is deliberately
# NOT prefixed with VITE_, so Vite cannot expose it to the client bundle.
ANTHROPIC_API_KEY=sk-ant-...

# Model selection (all optional). The app tags each request with a tier:
#   - "quality" for roadmap decomposition (goals -> subgoals -> milestones)
#   - "fast"    for high-volume routine work (daily plans, opportunity extraction)
# The proxy maps each tier to a model, with these defaults:
ANTHROPIC_MODEL_QUALITY=claude-sonnet-4-6
ANTHROPIC_MODEL_FAST=claude-haiku-4-5-20251001
# Or force ONE model for EVERY call (overrides both tiers above). Leave blank to
# use the per-tier defaults. Example: ANTHROPIC_MODEL=claude-opus-4-8
# ANTHROPIC_MODEL=

# Client-visible switch (safe to expose — a boolean, not a secret). Set to "true"
# to route AI through the local proxy to real Claude. Anything else (or unset)
# uses the deterministic MockAI, so the app still works with no key.
VITE_USE_REAL_AI=true
